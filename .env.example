# ============================================================
#  SOLEMART — ENVIRONMENT VARIABLES
#  Copy this file to .env and fill in your values
#  Never commit .env to version control
# ============================================================

# ── SERVER ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development          # development | production

# ── DATABASE ──────────────────────────────────────────────────
# Full PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/solemart

# ── JWT ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m            # access token lifetime
JWT_REFRESH_EXPIRES_IN=30d    # refresh token lifetime

# ── BCRYPT ────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── STRIPE ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── EMAIL (Nodemailer) ────────────────────────────────────────
# For production use SendGrid, Resend, or AWS SES
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hello@solemart.co.uk
SMTP_PASS=your_app_password
EMAIL_FROM="SoleMart <hello@solemart.co.uk>"

# ── FILE STORAGE (Cloudflare R2 / AWS S3) ────────────────────
STORAGE_PROVIDER=r2           # r2 | s3
STORAGE_BUCKET=solemart-assets
STORAGE_ENDPOINT=https://your-account.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key
STORAGE_PUBLIC_URL=https://assets.solemart.co.uk

# ── POSTCODE API ──────────────────────────────────────────────
# Postcodes.io is free and open — no key needed
# Override with a paid provider (Ideal Postcodes, GetAddress.io) for production
POSTCODE_API_URL=https://api.postcodes.io

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://solemart.co.uk

# ── RATE LIMITING ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX=100            # requests per window
AUTH_RATE_LIMIT_MAX=10        # stricter limit on auth routes

# ── ENCRYPTION (for bank details) ────────────────────────────
# 32-byte hex key — generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_32_byte_hex_encryption_key

# ── ADMIN ─────────────────────────────────────────────────────
# Initial admin user (used by seed script only)
ADMIN_EMAIL=admin@solemart.co.uk
ADMIN_PASSWORD=change_me_immediately
